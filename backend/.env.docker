# ── Configuração para Docker Compose ────────────────────

# Banco de Dados - usa o nome do serviço 'db' do docker-compose
POSTGRES_USER=capsule
POSTGRES_PASSWORD=capsule123
POSTGRES_DB=capsule_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production-12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Ambiente
ENVIRONMENT=production
